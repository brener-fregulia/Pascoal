{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pascoal",
  "version": "0.20.0",
  "identifier": "com.brener-fregulia.pascoal",
  "build": {
    "beforeDevCommand": "npm run dev:ide",
    "beforeBuildCommand": "npm run build:ide",
    "frontendDist": "../src/renderer/ide/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Pascoal",
        "width": 1600,
        "height": 900,
        "resizable": true,
        "decorations": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
