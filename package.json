{
  "name": "pascoal",
  "productName": "Pascoal",
  "version": "0.13.0",
  "description": "Pascal Playground - Pascoal",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "dev:ide": "cd src/renderer/ide && npx vite",
    "build:ide": "cd src/renderer/ide && npx vite build",
    "test:frontend": "cd src/renderer/ide && npx vitest run",
    "test:frontend:watch": "cd src/renderer/ide && npx vitest",
    "test:rust": "cd src-tauri && cargo test",
    "test": "npm run test:frontend && npm run test:rust",
    "set-version": "node scripts/set-version.cjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brener-fregulia/Pascoal.git"
  },
  "author": "Brener Fregulia",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/brener-fregulia/Pascoal/issues"
  },
  "homepage": "https://github.com/brener-fregulia/Pascoal#readme",
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@tsconfig/svelte": "^5.0.8",
    "cross-env": "^7.0.3",
    "electron": "^42.4.0",
    "jsdom": "^29.1.1",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "ace-builds": "^1.44.0",
    "mustache": "^4.2.0",
    "node-pty": "^1.0.0"
  },
  "allowScripts": {
    "electron@42.4.0": true,
    "node-pty@1.1.0": true
  }
}
