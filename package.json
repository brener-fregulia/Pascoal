{
  "name": "pascoal",
  "productName": "Pascoal",
  "version": "0.20.0",
  "description": "Pascal Playground - Pascoal",
  "main": "src/main/main.js",
  "scripts": {
    "dev:ide": "cd src/renderer/ide && npx vite",
    "build:ide": "cd src/renderer/ide && npx vite build",
    "set-version": "node scripts/set-version.cjs",
    "test:frontend": "cd src/renderer/ide && npx vitest run",
    "test:frontend:watch": "cd src/renderer/ide && npx vitest",
    "test:rust": "cd src-tauri && cargo test --lib",
    "test:pascal": "cd src-tauri && cargo test --test pascal_runner -- --nocapture",
    "test": "npm run test:frontend && npm run test:rust && npm run test:pascal"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brener-fregulia/Pascoal.git"
  },
  "author": "Brener Fregulia",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/brener-fregulia/Pascoal/issues"
  },
  "homepage": "https://github.com/brener-fregulia/Pascoal#readme",
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^25.9.3",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.1",
    "@tauri-apps/api": "^2.11.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0"
  }
}
